// Turso (libSQL) database; the app connects through the driver adapter in src/backend/db.ts.
// DATABASE_URL is only used by the Prisma CLI (points at a local file placeholder).
datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// Application user for email/password login
model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String   // bcrypt hash, never the plain password
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Agent {
  id              String   @id @default(uuid())
  company         String
  financialStatus String?
  fullAddress     String?
  city            String?
  country         String
  rating          Float?
  coverage        String?
  operation       String?
  transportMode   String?
  services        String?
  contacts        String?   // comma-separated or JSON list
  segments        String?
  networks        String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
